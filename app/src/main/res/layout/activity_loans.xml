<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF2F9">

    <!-- Professional Header -->
    <View
        android:id="@+id/headerDecorator"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#D81B60"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/loansTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:text="Financial Support"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/loansSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="48dp"
        android:text="Bridging the credit gap for women"
        android:textColor="#CCFFFFFF"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/loansTitle"
        app:layout_constraintTop_toBottomOf="@id/loansTitle" />

    <!-- Search Section -->
    <LinearLayout
        android:id="@+id/searchSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/search_bg"
        android:elevation="4dp"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintTop_toBottomOf="@id/loansSubtitle">

        <EditText
            android:id="@+id/etOtherBank"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Type your bank of choice..."
            android:paddingHorizontal="16dp"
            android:textSize="14sp" />

        <ImageButton
            android:id="@+id/btnSearchBank"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/circular_btn_bg"
            android:src="@android:drawable/ic_menu_search"
            android:contentDescription="Search Bank"
            android:tint="@color/white"
            app:tint="@color/white" />
    </LinearLayout>

    <!-- Loan List Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/listCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchSection">

        <ListView
            android:id="@+id/loanList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp"
            android:padding="12dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_loan_provider" />

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
